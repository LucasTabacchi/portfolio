---
import '../styles/global.css';
import { profile } from '../data/portfolio';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  activePage?: string;
  ogImage?: string;
}

const {
  title = `${profile.name} — Portfolio`,
  description = 'Portfolio de Lucas Tabacchi — Fullstack Developer orientado a producto. React, Next.js, Django, TypeScript.',
  activePage = 'home',
  ogImage = '/og-default.png',
} = Astro.props;

const year = new Date().getFullYear();
const initials = profile.name.split(' ').map((n: string) => n[0]).join('').slice(0, 2);
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
---
<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <ViewTransitions />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#030712" />
    <meta name="author" content="Lucas Tabacchi" />
    <meta name="robots" content="index, follow" />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:site_name" content={`${profile.name} — Portfolio`} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 40 40'%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0' y1='0' x2='1' y2='1'%3E%3Cstop offset='0' stop-color='%238b5cf6'/%3E%3Cstop offset='1' stop-color='%2338bdf8'/%3E%3C/linearGradient%3E%3C/defs%3E%3Crect width='40' height='40' rx='10' fill='url(%23g)'/%3E%3Ctext x='50%25' y='55%25' dominant-baseline='middle' text-anchor='middle' font-family='system-ui,sans-serif' font-weight='800' font-size='18' fill='white'%3ELT%3C/text%3E%3C/svg%3E" />

    <!-- Structured Data: Person + WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': 'Person',
          name: profile.name,
          url: Astro.site?.toString(),
          jobTitle: 'Fullstack Developer',
          email: profile.email,
          sameAs: [
            profile.github,
            profile.linkedin,
          ],
          address: {
            '@type': 'PostalAddress',
            addressLocality: 'Concepción del Uruguay',
            addressRegion: 'Entre Ríos',
            addressCountry: 'AR',
          },
        },
        {
          '@type': 'WebSite',
          name: `${profile.name} — Portfolio`,
          url: Astro.site?.toString(),
          description: description,
          inLanguage: 'es',
        },
      ],
    })} />
  </head>
  <body>

    <!-- Skip link (Accessibility: WCAG 2.4.1) -->
    <a href="#main-content" class="skip-link">Ir al contenido principal</a>

    <!-- Scroll progress bar -->
    <div id="scroll-progress" aria-hidden="true"></div>

    <!-- Cursor glow effect -->
    <div class="cursor-glow" id="cursor-glow" aria-hidden="true"></div>

    <!-- Back to top -->
    <button id="back-to-top" aria-label="Volver arriba">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="18 15 12 9 6 15"/></svg>
    </button>



    <div class="main-wrapper">
      <!-- Particle canvas -->
      <canvas id="particles-canvas" aria-hidden="true"></canvas>

      <header class="navbar" id="main-navbar" role="banner">
        <a href="/#home" class="nav-logo" aria-label={`${profile.name} — Ir al inicio`}>
          <div class="nav-logo-icon" data-initials={initials} aria-hidden="true"></div>
          <div class="logo-text">
            <span class="logo-name">{profile.name}</span>
          </div>
        </a>

        <button class="nav-toggle" id="nav-toggle" aria-label="Abrir menú" aria-expanded="false" aria-controls="nav-links">
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
        </button>

        <nav class="nav-links" id="nav-links" aria-label="Navegación principal">
          <a href="/#works" class={`nav-link ${activePage === 'works' ? 'active' : ''}`} {...(activePage === 'works' ? {'aria-current': 'page'} : {})}>Proyectos</a>
          <a href="/#skills" class="nav-link">Skills</a>
          <a href="/#about-me" class={`nav-link ${activePage === 'about' ? 'active' : ''}`} {...(activePage === 'about' ? {'aria-current': 'page'} : {})}>Sobre mí</a>
          <a href="/#experience" class="nav-link">Trayectoria</a>
          <a href="/#contacts" class={`nav-link ${activePage === 'contacts' ? 'active' : ''}`} {...(activePage === 'contacts' ? {'aria-current': 'page'} : {})}>Contacto</a>
        </nav>
      </header>

      <main id="main-content"><slot /></main>

      <footer class="footer" role="contentinfo">
        <div class="footer-inner">
          <div>
            <div class="footer-logo-row">
              <div class="nav-logo-icon" data-initials={initials}></div>
              <div class="logo-text">
                <span class="logo-name">{profile.name}</span>
              </div>
            </div>
            <span class="footer-email" style="margin-bottom:0.75rem;display:block;">{profile.email}</span>
            <p class="footer-tagline">{profile.shortTitle}</p>
          </div>
          <div class="footer-media">
            <h4>Conectemos</h4>
            <div class="footer-social">
              <a href={profile.github} target="_blank" rel="noreferrer" aria-label="GitHub de Lucas Tabacchi">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
              </a>
              <a href={profile.linkedin} target="_blank" rel="noreferrer" aria-label="LinkedIn de Lucas Tabacchi">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4.98 3.5C4.98 4.88 3.86 6 2.48 6S0 4.88 0 3.5 1.12 1 2.5 1 5 2.12 4.98 3.5zM.5 8h4V24h-4V8zm7 0h3.83v2.19h.05C11.91 8.94 13.56 8 15.8 8 20.1 8 21 10.83 21 15.11V24h-4v-7.79c0-1.86-.03-4.25-2.59-4.25-2.6 0-3 2.02-3 4.12V24h-4V8z"/></svg>
              </a>
              <a href={`mailto:${profile.email}`} aria-label="Enviar email a Lucas Tabacchi">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 3.1-8 5.2-8-5.2V6l8 5.2L20 6v1.1z"/></svg>
              </a>
            </div>
          </div>
        </div>
        <p class="footer-copy">© {year} {profile.name} — Construido con Astro, código limpio y pasión por el producto.</p>
      </footer>
    </div>

    <script>
      // ── Scroll reveal observer ──
      const revealSelectors = '.scroll-reveal, .scroll-reveal-left, .scroll-reveal-right, .scroll-reveal-scale';
      const reveals = document.querySelectorAll(revealSelectors);
      const observer = new IntersectionObserver(
        (entries) => entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
          }
        }),
        { threshold: 0.06, rootMargin: '0px 0px -40px 0px' }
      );
      reveals.forEach(el => observer.observe(el));

      // ── Mobile nav toggle ──
      const toggle = document.getElementById('nav-toggle');
      const navLinks = document.getElementById('nav-links');
      if (toggle && navLinks) {
        toggle.addEventListener('click', () => {
          const isOpen = navLinks.classList.toggle('open');
          toggle.classList.toggle('active');
          toggle.setAttribute('aria-expanded', String(isOpen));
        });
        // Close on link click
        navLinks.querySelectorAll('.nav-link').forEach(link => {
          link.addEventListener('click', () => {
            navLinks.classList.remove('open');
            toggle.classList.remove('active');
            toggle.setAttribute('aria-expanded', 'false');
          });
        });
      }

      // ── Cursor glow (desktop) ──
      const glow = document.getElementById('cursor-glow');
      if (glow && window.innerWidth > 900) {
        let mouseX = 0, mouseY = 0;
        let glowX = 0, glowY = 0;
        
        document.addEventListener('mousemove', (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;
        });

        function animateGlow() {
          glowX += (mouseX - glowX) * 0.08;
          glowY += (mouseY - glowY) * 0.08;
          glow!.style.left = glowX + 'px';
          glow!.style.top = glowY + 'px';
          requestAnimationFrame(animateGlow);
        }
        animateGlow();
      } else if (glow) {
        glow.style.display = 'none';
      }

      // ── Particles — premium animated background ──
      const canvas = document.getElementById('particles-canvas') as HTMLCanvasElement;
      if (canvas) {
        const ctx = canvas.getContext('2d')!;
        let animId: number;
        let mouseX = -9999, mouseY = -9999;

        // Track mouse globally (canvas is fixed, full-screen)
        window.addEventListener('mousemove', (e) => { mouseX = e.clientX; mouseY = e.clientY; });

        // ── Types ──
        type Particle = {
          x: number; y: number; vx: number; vy: number;
          size: number; baseOpacity: number; opacity: number;
          colorR: number; colorG: number; colorB: number;
          pulse: number; pulseSpeed: number; glowSize: number;
          type: 'dot' | 'star';
        };
        type Nebula = { x: number; y: number; r: number; colorStr: string; phase: number; speed: number; };

        let particles: Particle[] = [];
        let nebulas: Nebula[] = [];

        function resize() {
          canvas.width  = window.innerWidth;
          canvas.height = window.innerHeight;
        }

        function initScene() {
          particles = [];
          nebulas   = [];

          // ── Nebula blobs (large soft background orbs) ──
          const nebulaColors = [
            '139,92,246', '56,189,248', '192,132,252', '99,102,241'
          ];
          const nebulaCount = 5;
          for (let i = 0; i < nebulaCount; i++) {
            nebulas.push({
              x: Math.random() * canvas.width,
              y: Math.random() * canvas.height,
              r: 200 + Math.random() * 300,
              colorStr: nebulaColors[i % nebulaColors.length],
              phase: Math.random() * Math.PI * 2,
              speed: 0.003 + Math.random() * 0.004,
            });
          }

          // ── Particles ──
          const palette: [number,number,number][] = [
            [139, 92, 246],   // violet
            [56,  189, 248],  // sky blue
            [167, 139, 250],  // light violet
            [192, 132, 252],  // pink-purple
            [34,  211, 238],  // cyan
            [248, 250, 252],  // near-white star
          ];
          const density  = window.innerWidth < 768 ? 30000 : 14000;
          const maxCount = window.innerWidth < 768 ? 60 : 130;
          const count    = Math.min(Math.floor(canvas.width * canvas.height / density), maxCount);

          for (let i = 0; i < count; i++) {
            const isStar = Math.random() < 0.25; // 25% stars
            const [r, g, b] = palette[Math.floor(Math.random() * (isStar ? 1 : palette.length - 1))];
            const baseOpacity = isStar
              ? 0.4 + Math.random() * 0.6
              : 0.25 + Math.random() * 0.5;

            particles.push({
              x: Math.random() * canvas.width,
              y: Math.random() * canvas.height,
              vx: (Math.random() - 0.5) * (isStar ? 0.1 : 0.3),
              vy: (Math.random() - 0.5) * (isStar ? 0.1 : 0.3),
              size: isStar ? 0.8 + Math.random() * 1.2 : 1.5 + Math.random() * 2.5,
              baseOpacity,
              opacity: baseOpacity,
              colorR: r, colorG: g, colorB: b,
              pulse: Math.random() * Math.PI * 2,
              pulseSpeed: 0.008 + Math.random() * 0.025,
              glowSize: isStar ? 2 : 4 + Math.random() * 6,
              type: isStar ? 'star' : 'dot',
            });
          }
        }

        function draw() {
          ctx.clearRect(0, 0, canvas.width, canvas.height);

          // ── Draw nebula blobs ──
          for (const n of nebulas) {
            n.phase += n.speed;
            const pulse = 0.85 + Math.sin(n.phase) * 0.15;
            const grad = ctx.createRadialGradient(n.x, n.y, 0, n.x, n.y, n.r * pulse);
            grad.addColorStop(0,   `rgba(${n.colorStr}, 0.045)`);
            grad.addColorStop(0.4, `rgba(${n.colorStr}, 0.02)`);
            grad.addColorStop(1,   `rgba(${n.colorStr}, 0)`);
            ctx.beginPath();
            ctx.arc(n.x, n.y, n.r * pulse, 0, Math.PI * 2);
            ctx.fillStyle = grad;
            ctx.fill();
          }

          // ── Draw connection lines first (behind particles) ──
          for (let i = 0; i < particles.length; i++) {
            const p = particles[i];
            for (let j = i + 1; j < particles.length; j++) {
              const q  = particles[j];
              const dx = p.x - q.x, dy = p.y - q.y;
              const d  = Math.sqrt(dx * dx + dy * dy);
              const maxDist = 160;
              if (d < maxDist) {
                const t = 1 - d / maxDist;
                // Gradient line from p's color to q's color
                const lg = ctx.createLinearGradient(p.x, p.y, q.x, q.y);
                lg.addColorStop(0, `rgba(${p.colorR},${p.colorG},${p.colorB},${t * 0.18})`);
                lg.addColorStop(1, `rgba(${q.colorR},${q.colorG},${q.colorB},${t * 0.08})`);
                ctx.beginPath();
                ctx.moveTo(p.x, p.y);
                ctx.lineTo(q.x, q.y);
                ctx.strokeStyle = lg;
                ctx.lineWidth = t * 0.8;
                ctx.stroke();
              }
            }
          }

          // ── Draw particles ──
          for (const p of particles) {
            p.pulse += p.pulseSpeed;
            const pulseFactor = 0.65 + Math.sin(p.pulse) * 0.35;
            p.opacity = p.baseOpacity * pulseFactor;

            // Mouse repulsion
            const mdx = p.x - mouseX, mdy = p.y - mouseY;
            const md  = Math.sqrt(mdx * mdx + mdy * mdy);
            if (md < 180 && md > 0) {
              const f = ((180 - md) / 180) * 0.18;
              p.vx += (mdx / md) * f;
              p.vy += (mdy / md) * f;
            }
            p.vx *= 0.985; p.vy *= 0.985;
            p.x  += p.vx;  p.y  += p.vy;

            if (p.x < -10) p.x = canvas.width  + 10;
            if (p.x > canvas.width  + 10) p.x = -10;
            if (p.y < -10) p.y = canvas.height + 10;
            if (p.y > canvas.height + 10) p.y = -10;

            const { colorR: r, colorG: g, colorB: b } = p;

            // Glow halo
            const glow = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.size * p.glowSize);
            glow.addColorStop(0,   `rgba(${r},${g},${b},${p.opacity * 0.6})`);
            glow.addColorStop(0.3, `rgba(${r},${g},${b},${p.opacity * 0.2})`);
            glow.addColorStop(1,   `rgba(${r},${g},${b},0)`);
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.size * p.glowSize, 0, Math.PI * 2);
            ctx.fillStyle = glow;
            ctx.fill();

            // Core dot
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(${r},${g},${b},${p.opacity})`;
            ctx.fill();

            // Star cross-flare for star type
            if (p.type === 'star') {
              ctx.save();
              ctx.globalAlpha = p.opacity * 0.6;
              ctx.strokeStyle = `rgb(${r},${g},${b})`;
              ctx.lineWidth   = 0.5;
              const fl = p.size * 4;
              ctx.beginPath();
              ctx.moveTo(p.x - fl, p.y); ctx.lineTo(p.x + fl, p.y);
              ctx.moveTo(p.x, p.y - fl); ctx.lineTo(p.x, p.y + fl);
              ctx.stroke();
              ctx.restore();
            }
          }

          animId = requestAnimationFrame(draw);
        }

        resize();
        initScene();
        draw();

        window.addEventListener('resize', () => { resize(); initScene(); });
        document.addEventListener('visibilitychange', () => {
          if (document.hidden) cancelAnimationFrame(animId); else draw();
        });
      }

      // ── Navbar scroll effect ──
      const navbar = document.getElementById('main-navbar');
      if (navbar) {
        let ticking = false;
        window.addEventListener('scroll', () => {
          if (!ticking) {
            requestAnimationFrame(() => {
              const current = window.scrollY;
              if (current > 80) {
                navbar.classList.add('scrolled');
              } else {
                navbar.classList.remove('scrolled');
              }
              ticking = false;
            });
            ticking = true;
          }
        }, { passive: true });
      }

      // ── Smooth anchor scrolling ──
      document.querySelectorAll('a[href^="/#"]').forEach(anchor => {
        anchor.addEventListener('click', function(this: HTMLAnchorElement, e: Event) {
          const href = this.getAttribute('href');
          if (href) {
            const targetId = href.replace('/', '');
            const targetEl = document.querySelector(targetId);
            if (targetEl) {
              e.preventDefault();
              targetEl.scrollIntoView({ behavior: 'smooth' });
            }
          }
        });
      });

      // ── Scroll progress bar ──
      const progressBar = document.getElementById('scroll-progress');
      if (progressBar) {
        window.addEventListener('scroll', () => {
          const total = document.documentElement.scrollHeight - window.innerHeight;
          const pct   = total > 0 ? (window.scrollY / total) * 100 : 0;
          progressBar.style.width = pct + '%';
        }, { passive: true });
      }

      // ── Back to top button ──
      const btt = document.getElementById('back-to-top');
      if (btt) {
        window.addEventListener('scroll', () => {
          btt.classList.toggle('visible', window.scrollY > 400);
        }, { passive: true });
        btt.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }

      // ── Active nav section tracking ──
      const sectionIds  = ['home','works','skills','about-me','experience','contacts'];
      const navLinkEls  = document.querySelectorAll('.nav-link');

      const sectionObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            navLinkEls.forEach(link => {
              const href = link.getAttribute('href') || '';
              const matches = href.includes(id) || (id === 'home' && href.includes('/#home'));
              link.classList.toggle('active', matches);
            });
          }
        });
      }, { threshold: 0.3, rootMargin: '-80px 0px -40% 0px' });

      sectionIds.forEach(id => {
        const el = document.getElementById(id);
        if (el) sectionObserver.observe(el);
      });
    </script>
  </body>
</html>
