---
import Layout from '../layouts/Layout.astro';
import { profile, skillGroups } from '../data/portfolio';
---
<Layout title={`About — ${profile.name}`} activePage="about" description="Conocé más sobre Lucas Tabacchi: desarrollador fullstack orientado a producto, con experiencia en React, Next.js, Django y TypeScript.">
  <div class="about-page">
    <div class="page-title-row animate-fade-up">
      <h1 class="page-h1">Sobre mí</h1>
      <span class="title-line"></span>
    </div>
    <p class="page-sub animate-fade-up-2">¿Quién soy?</p>

    <div class="about-layout">
      <div class="about-text scroll-reveal">
        <p class="hello">Hola, soy <span class="name-highlight">{profile.name}</span>!</p>
        {profile.about.map((paragraph) => <p class="body-p">{paragraph}</p>)}
      </div>

      <div class="about-figure scroll-reveal-right">
        <div class="figure-wrap">
          <img src="/video-assets/about-figure.png" alt="About figure" />
          <div class="figure-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Open to work
          </div>
        </div>
      </div>
    </div>

    <section class="skills-section">
      <h2 class="section-h scroll-reveal">Skills</h2>

      <div class="skills-grid">
        {skillGroups.map((group, i) => (
          <div class="sk-box glass-card scroll-reveal" style={`transition-delay:${i*0.08}s`}>
            <h4 class="sk-title">{group.title}</h4>
            <div class="sk-items">
              {group.items.map((item) => <span class="skill-chip">{item}</span>)}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="facts-section scroll-reveal">
      <h2 class="section-h"><span class="sh"></span>Cómo trabajo</h2>

      <div class="facts-wrap">
        {profile.principles.map((principle, i) => (
          <div class="fact-pill" style={`transition-delay:${i*0.1}s`}>
            <span class="fact-icon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            {principle}
          </div>
        ))}
      </div>
    </section>
  </div>
</Layout>

<style>
  .about-page { padding: 2rem 2.5rem 5rem; }

  .page-title-row { display: flex; align-items: center; }
  .slash { color: var(--accent); font-size: 1.5rem; font-family: var(--font-head); font-weight: 700; }
  .page-h1 { font-size: 1.5rem; color: var(--text-bright); font-weight: 600; font-family: var(--font-head); }
  .title-line {
    flex: 1; max-width: 200px; height: 1px;
    background: linear-gradient(90deg, var(--accent), transparent);
    opacity: 0.4; margin-left: 1rem;
  }
  .page-sub { font-size: 0.88rem; color: var(--text-dim); margin: 0.5rem 0 3rem; }

  .about-layout {
    display: grid; grid-template-columns: 1fr auto;
    gap: 4rem; align-items: start; margin-bottom: 5rem;
  }

  .hello {
    font-family: var(--font-head); font-size: 1.15rem; font-weight: 600;
    color: var(--text-bright); margin-bottom: 1.25rem;
  }
  .name-highlight {
    background: linear-gradient(135deg, var(--accent), var(--accent3));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .body-p {
    font-size: 0.9rem; color: var(--text); line-height: 1.9;
    margin-bottom: 0.85rem; max-width: 580px;
  }

  .about-figure { width: 400px; }
  .figure-wrap {
    position: relative; border-radius: var(--radius-xl); overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
  }
  .figure-wrap img { width: 100%; display: block; }

  .figure-badge {
    position: absolute; bottom: 1rem; left: 50%; transform: translateX(-50%);
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.4rem 1rem; background: rgba(3,7,18,0.9);
    border: 1px solid rgba(52,211,153,0.3); border-radius: 999px;
    font-size: 0.75rem; color: var(--emerald); backdrop-filter: blur(12px); white-space: nowrap;
  }

  .skills-section { margin-bottom: 4rem; }
  .section-h {
    font-size: 1.3rem; color: var(--text-bright); font-weight: 600;
    font-family: var(--font-head); margin-bottom: 2rem;
  }
  .sh { color: var(--accent); margin-right: 0.25rem; }

  .skills-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .sk-box { padding: 1.5rem; border-radius: var(--radius-lg); }

  .sk-title {
    font-size: 0.95rem; font-weight: 600; color: var(--text-bright);
    font-family: var(--font-head); margin-bottom: 0.85rem;
  }

  .sk-items { display: flex; flex-wrap: wrap; gap: 0.4rem; }

  .skill-chip {
    display: inline-flex; padding: 0.28rem 0.7rem;
    background: rgba(15,23,42,0.6); border: 1px solid var(--border);
    border-radius: var(--radius-sm); font-size: 0.78rem; color: var(--text);
    font-family: var(--font-mono); transition: all 0.3s var(--ease-out-expo);
  }
  .skill-chip:hover {
    color: var(--accent2); border-color: var(--border-accent);
    background: var(--accent-soft); transform: translateY(-2px);
  }

  .facts-section { margin-bottom: 2rem; }

  .facts-wrap { display: flex; flex-wrap: wrap; gap: 0.75rem; }

  .fact-pill {
    display: inline-flex; align-items: center; gap: 0.6rem;
    font-size: 0.85rem; color: var(--text);
    border: 1px solid var(--border); border-radius: var(--radius-sm);
    padding: 0.7rem 1.15rem; background: var(--glass-bg);
    backdrop-filter: blur(12px);
    transition: all 0.3s ease;
  }
  .fact-pill:hover {
    border-color: var(--border-accent);
    background: var(--accent-soft);
    transform: translateY(-2px);
  }

  .fact-icon {
    width: 24px; height: 24px;
    display: flex; align-items: center; justify-content: center;
    background: var(--accent-soft); border-radius: 6px; color: var(--accent2);
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    .about-layout { grid-template-columns: 1fr; }
    .about-figure { width: min(400px, 100%); }
    .skills-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .about-page { padding: 1.5rem 1.25rem 3rem; }
    .skills-grid { grid-template-columns: 1fr; }
  }
</style>
