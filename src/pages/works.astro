---
import Layout from '../layouts/Layout.astro';
import { featuredProjects, otherProjects, profile } from '../data/portfolio';
---
<Layout title={`Works — ${profile.name}`} activePage="works" description="Proyectos fullstack de Lucas Tabacchi: ecommerce, plataformas de gestión, herramientas Docker y más. Next.js, Django, TypeScript.">
  <div class="works-page">
    <div class="page-title-row animate-fade-up">
      <h1 class="page-h1">Proyectos</h1>
      <span class="title-line"></span>
    </div>
    <p class="page-sub animate-fade-up-2">Proyectos que construí de principio a fin</p>

    <section class="proj-section">
      <h2 class="group-title scroll-reveal">Apps completas</h2>

      <div class="works-grid">
        {featuredProjects.map((project, i) => (
          <article class="w-card glass-card scroll-reveal" style={`transition-delay:${i*0.1}s`}>
            <div class="w-preview" style={`background:${project.gradient}`}>
              <div class="w-preview-shell">
                <span class="w-accent">{project.accent}</span>
                <h3 class="w-preview-h3">{project.title}</h3>
                <div class="w-preview-tags">
                  {project.tags.slice(0, 3).map((tag) => <em>{tag}</em>)}
                </div>
              </div>
            </div>
            <div class="w-body">
              <p class="w-tags-text">{project.tags.join(' · ')}</p>
              <h3 class="w-title">{project.title}</h3>
              <p class="w-desc">{project.description}</p>
              <div class="w-btns">
                {project.demoUrl && (
                  <a href={project.demoUrl} class="btn" target="_blank" rel="noreferrer">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                    Demo
                  </a>
                )}
                <a href={project.repoUrl} class="btn btn-ghost" target="_blank" rel="noreferrer">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
                  GitHub
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="proj-section">
      <h2 class="group-title scroll-reveal">Otros proyectos</h2>

      <div class="small-grid">
        {otherProjects.map((project, i) => (
          <article class="s-card glass-card scroll-reveal" style={`transition-delay:${i*0.08}s`}>
            <div class="s-tags-row">
              {project.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
            <h3 class="s-title-text">{project.title}</h3>
            <p class="s-desc">{project.description}</p>
            <div class="w-btns" style="margin-top:auto;">
              <a href={project.repoUrl} class="btn btn-ghost" target="_blank" rel="noreferrer">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
                GitHub
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>
  </div>
</Layout>

<style>
  .works-page { padding: 2rem 2.5rem 5rem; }

  .page-title-row { display: flex; align-items: center; gap: 0; }
  .slash { color: var(--accent); font-size: 1.5rem; font-family: var(--font-head); font-weight: 700; }
  .page-h1 { font-size: 1.5rem; color: var(--text-bright); font-weight: 600; font-family: var(--font-head); }
  .title-line {
    flex: 1; max-width: 200px; height: 1px;
    background: linear-gradient(90deg, var(--accent), transparent);
    opacity: 0.4; margin-left: 1rem;
  }
  .page-sub { font-size: 0.88rem; color: var(--text-dim); margin: 0.5rem 0 3rem; }

  .proj-section { margin-bottom: 4rem; }
  .group-title {
    font-size: 1.2rem; color: var(--text-bright); font-weight: 600;
    font-family: var(--font-head); margin-bottom: 1.75rem;
  }
  .gh { color: var(--accent); margin-right: 0.25rem; }

  .works-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }

  .w-card {
    display: flex; flex-direction: column; overflow: hidden;
    border-radius: var(--radius-lg);
  }

  .w-preview { height: 180px; padding: 1.15rem; position: relative; overflow: hidden; }
  .w-preview::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(0,0,0,0.3));
    pointer-events: none;
  }
  .w-preview-shell { height: 100%; display: flex; flex-direction: column; justify-content: space-between; position: relative; z-index: 1; }
  .w-accent { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.65); }
  .w-preview h3, .w-preview-h3 { font-size: 1.8rem; font-family: var(--font-head); font-weight: 700; color: #fff; line-height: 1.05; max-width: 10ch; }
  .w-preview-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .w-preview em {
    border: 1px solid rgba(255,255,255,0.2); padding: 0.2rem 0.5rem;
    font-size: 0.65rem; font-style: normal; color: rgba(255,255,255,0.8);
    border-radius: 4px; backdrop-filter: blur(4px);
  }

  .w-body { padding: 1.15rem 1.25rem 1.25rem; display: flex; flex-direction: column; flex: 1; gap: 0.5rem; }
  .w-tags-text { font-size: 0.72rem; color: var(--text-dim); font-family: var(--font-mono); }
  .w-title { font-size: 1.1rem; font-weight: 600; color: var(--text-bright); font-family: var(--font-head); }
  .w-desc { font-size: 0.82rem; color: var(--text); margin-bottom: 0.5rem; line-height: 1.7; flex: 1; }
  .w-btns { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  .small-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }

  .s-card {
    padding: 1.25rem;
    display: flex; flex-direction: column; gap: 0.6rem;
    min-height: 180px; border-radius: var(--radius-lg);
  }
  .s-tags-row { display: flex; flex-wrap: wrap; gap: 0.35rem; }
  .s-title-text { font-size: 1rem; font-weight: 600; color: var(--text-bright); font-family: var(--font-head); }
  .s-desc { font-size: 0.82rem; color: var(--text); line-height: 1.7; flex: 1; }

  @media (max-width: 1024px) {
    .works-grid { grid-template-columns: repeat(2, 1fr); }
    .small-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .works-page { padding: 1.5rem 1.25rem 3rem; }
    .works-grid, .small-grid { grid-template-columns: 1fr; }
  }
</style>
